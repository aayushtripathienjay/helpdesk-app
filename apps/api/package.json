{
  "name": "@helpdesk/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "prisma generate && bun --watch src/index.ts",
    "build": "prisma generate && tsc -p tsconfig.json",
    "test": "bun test ./src/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "bun src/scripts/seed-admin.ts",
    "db:test:reset": "bun src/scripts/reset-test-db.ts",
    "db:test:seed": "bun src/scripts/seed-e2e-users.ts"
  },
  "dependencies": {
    "@ai-sdk/google": "^4.0.8",
    "@prisma/client": "^6.1.0",
    "ai": "^7.0.15",
    "better-auth": "^1.6.23",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.0.1",
    "pg-boss": "^12.25.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "prisma": "^6.1.0"
  }
}
